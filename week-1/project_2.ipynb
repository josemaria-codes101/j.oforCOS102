   "source": [
    "# Compound Interest\n",
    "P = float(input('Enter Principal (P): '))\n",
    "R = float(input('Enter Rate (R): '))\n",
    "n = float(input('Enter value for n: '))\n",
    "t = float(input('Enter value for t: '))\n",
    "\n",
    "A = P * (1 + (R / n)) ** (n * t)\n",
    "print('Compound Interest: ', A)\n"
   ]
