   "source": [
    "# Annuity Plan\n",
    "PMT = float(input('Enter Periodic Payment (PMT): '))\n",
    "R = float(input('Enter Rate (R): '))\n",
    "n = float(input('Enter value for n: '))\n",
    "t = float(input('Enter value for t: '))\n",
    "\n",
    "A = PMT * (((1 + (R / n)) ** (n * t)) - 1) / (R / n)\n",
    "print('Annuity Plan: ', A)"
   ]
